# MySQL Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=ids_app
DB_PASSWORD=
DB_DATABASE=ids_ips_db

# JWT Secret and Expiration Settings
# IMPORTANT: Use a strong, random secret key (at least 32 characters) in production
JWT_SECRET=
JWT_EXPIRATION=1h

# Wazuh SIEM Manager API Settings
WAZUH_API_URL=https://192.168.101.128:55000
WAZUH_API_USER=wazuh-wui
WAZUH_API_PASSWORD=
# Set to 'false' to disable SSL verification for self-signed certificates (NOT recommended for production)
WAZUH_SSL_VERIFY=true

# Backend Listening Port
PORT=3000

# CORS Allowed Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://192.168.101.128:5173
